#!/usr/bin/env bash
set -euo pipefail
trap 'exit 0' ERR

# Vaultsmith PreToolUse hook for Bash tool
# - BLOCKS shell commands that would read secret/credential files into context.
# - For SUSPICIOUS-but-not-blocked patterns (e.g. curl-to-shell, base64-to-shell,
#   eval $(curl ...)), force re-consent by locking the vault-session daemon
#   cache. The command itself is allowed to run; if it tries to access vault
#   secrets, the user will be re-prompted instead of inheriting warm consent.

if [[ -z "${PLUGIN_DIR:-}" ]]; then
  PLUGIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
fi

INPUT="$(cat)"

# Extract command using jq, fall back to grep/sed
if command -v jq &>/dev/null; then
  CMD="$(echo "$INPUT" | jq -r '.tool_input.command // empty')"
else
  CMD="$(echo "$INPUT" | grep -o '"command"[[:space:]]*:[[:space:]]*"[^"]*"' | sed 's/.*"command"[[:space:]]*:[[:space:]]*"//;s/"$//')"
fi

[ -z "$CMD" ] && exit 0

# Denied file patterns (used in regex)
# Matches paths like ~/.aws/credentials, /home/user/.aws/credentials, .env, .env.local, etc.
SECRET_PATH_RE='(\.aws/credentials|\.aws/config|\.npmrc|\.netrc|\.git-credentials|\.docker/config\.json|\.env(\.[a-zA-Z0-9_]+)?(\s|$|"|'"'"'))'

# Denied env var names
SECRET_VAR_RE='(AWS_SECRET_ACCESS_KEY|AWS_SESSION_TOKEN|AWS_ACCESS_KEY_ID|GITHUB_TOKEN|NPM_TOKEN|DOCKER_PASSWORD|DATABASE_URL|DB_PASSWORD|API_KEY|SECRET_KEY|PRIVATE_KEY)'

BLOCKED=false

# 1. File-reading commands followed by a secret path
if echo "$CMD" | grep -qE "(cat|head|tail|less|more|bat)\s+.*${SECRET_PATH_RE}"; then
  BLOCKED=true
fi

# 2. echo/printf of secret env vars
if echo "$CMD" | grep -qE '(echo|printf)\s+.*\$\{?'"${SECRET_VAR_RE}"'\}?'; then
  BLOCKED=true
fi

# 3. printenv with secret var names
if echo "$CMD" | grep -qE "printenv\s+${SECRET_VAR_RE}"; then
  BLOCKED=true
fi

# 4. source .env or . .env
if echo "$CMD" | grep -qE '(source|\.\s+).*\.env(\.[a-zA-Z0-9_]+)?(\s|$)'; then
  BLOCKED=true
fi

# 5. Redirect reads: < .env or $(<.env)
if echo "$CMD" | grep -qE '<\s*\.env(\.[a-zA-Z0-9_]+)?(\s|$|\))'; then
  BLOCKED=true
fi

# 6. Redirect reads of other secret files
if echo "$CMD" | grep -qE "<\s*.*${SECRET_PATH_RE}"; then
  BLOCKED=true
fi

if [ "$BLOCKED" = true ]; then
  printf '{"decision":"block","reason":"Vaultsmith: blocked bash command that reads secret files. Use vault-run wrapper instead."}'
  exit 0
fi

# --- Suspicious-but-not-blocked patterns: lock vault, then allow command ---
#
# These are network-to-execute patterns frequently abused by supply-chain
# attacks. We do NOT block (legit installers use these too), but we lock
# the vault-session cache so any subsequent secret access re-prompts.

SUSPICIOUS=false

# curl|wget piped to a shell
if echo "$CMD" | grep -qE '(curl|wget)[^|]*\|[[:space:]]*(sh|bash|zsh)([[:space:]]|$|;)'; then
  SUSPICIOUS=true
fi

# eval $(curl ...) or eval `curl ...`
if echo "$CMD" | grep -qE 'eval[[:space:]]+["$`(]+[[:space:]]*(curl|wget)'; then
  SUSPICIOUS=true
fi

# base64 -d / -D / --decode piped to a shell
if echo "$CMD" | grep -qE 'base64[[:space:]]+(-d|-D|--decode)[^|]*\|[[:space:]]*(sh|bash|zsh)'; then
  SUSPICIOUS=true
fi

# curl|wget piped to an interpreter executing inline code
if echo "$CMD" | grep -qE '(curl|wget)[^|]*\|[[:space:]]*(python3?|node|ruby|perl)[[:space:]]+-c'; then
  SUSPICIOUS=true
fi

if [ "$SUSPICIOUS" = true ]; then
  "${PLUGIN_DIR}/bin/vault-lock" --all >/dev/null 2>&1 || true
fi

exit 0
