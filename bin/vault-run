#!/usr/bin/env bash
set -euo pipefail

# vault-run: resolve vsm:// secret references in env vars, then exec the command.
#
# Consent model (macOS): items stored by vaultsmith use an empty trusted-apps
# ACL (`security add-generic-password -T ""`), so every keychain read triggers
# a native Keychain Access dialog. To keep the UX per-SESSION rather than
# per-command, vault-run routes macOS resolutions through the vault-session
# daemon, which caches resolved values in memory for the lifetime of the
# controlling TTY (or anchor PID when there's no TTY). One prompt per secret
# per session; close the terminal or run `vault-lock` to force re-consent.
# Linux still shells directly to secret-tool (no per-item prompt mechanic).

usage() {
  cat >&2 <<'USAGE'
Usage: vault-run -- <command> [args...]

Resolves vsm:// secret references in environment variables via the OS
keychain, then spawns the given command with the resolved environment.

Example:
  export DB_PASSWORD=vsm://db/prod/password
  vault-run -- psql -h localhost mydb
USAGE
  exit 1
}

# --- Parse args: find the -- separator ---

separator_found=false
cmd_args=()
for arg in "$@"; do
  if [[ "$separator_found" == true ]]; then
    cmd_args+=("$arg")
  elif [[ "$arg" == "--" ]]; then
    separator_found=true
  fi
done

if [[ "$separator_found" == false ]]; then
  echo "Error: missing '--' separator before the command." >&2
  usage
fi

if [[ ${#cmd_args[@]} -eq 0 ]]; then
  echo "Error: no command specified after '--'." >&2
  usage
fi

# --- Detect platform ---

platform="$(uname -s)"
case "$platform" in
  Darwin) ;;
  Linux)  ;;
  *)
    echo "Error: unsupported platform '$platform'." >&2
    exit 1
    ;;
esac

# --- Resolve plugin dir + session anchor (macOS only) ---

if [[ -z "${PLUGIN_DIR:-}" ]]; then
  PLUGIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
fi

if [[ "$platform" == "Darwin" ]]; then
  # Walk up the process tree to find the controlling TTY. The Bash tool
  # invocations inside Claude often have no TTY of their own, but a parent
  # process does — anchoring there lets sub-agents in the same terminal pane
  # share the daemon cache.
  detect_tty() {
    local pid=$$
    local tty
    while [[ "$pid" -gt 1 ]]; do
      tty="$(ps -o tty= -p "$pid" 2>/dev/null | tr -d ' ')"
      if [[ -n "$tty" && "$tty" != "?" && "$tty" != "??" ]]; then
        echo "/dev/$tty"
        return 0
      fi
      pid="$(ps -o ppid= -p "$pid" 2>/dev/null | tr -d ' ')"
      [[ -z "$pid" || "$pid" == "0" ]] && break
    done
    return 1
  }

  if tty_path="$(detect_tty)" && [[ -e "$tty_path" ]]; then
    export VAULTSMITH_ANCHOR_TTY="$tty_path"
  else
    # No TTY found — fall back to anchoring on the parent PID. Daemon will
    # exit when that PID is gone.
    export VAULTSMITH_ANCHOR_PID="$PPID"
  fi
fi

# --- Resolve vsm:// references ---

resolve_secret() {
  local ref="$1"
  # Strip the vsm:// prefix to get the keychain account name
  local name="${ref#vsm://}"

  case "$platform" in
    Darwin)
      "${PLUGIN_DIR}/bin/vault-resolve" "$name"
      ;;
    Linux)
      secret-tool lookup service vaultsmith account "$name" 2>/dev/null
      ;;
  esac
}

while IFS='=' read -r var_name var_value; do
  if [[ "$var_value" == vsm://* ]]; then
    resolved="$(resolve_secret "$var_value")" || {
      echo "Error: failed to resolve secret reference '$var_value' for env var '$var_name'." >&2
      exit 1
    }
    if [[ -z "$resolved" ]]; then
      echo "Error: empty value returned for secret reference '$var_value' (env var '$var_name')." >&2
      exit 1
    fi
    export "$var_name=$resolved"
  fi
done < <(env)

# --- Exec the child command ---

exec "${cmd_args[@]}"
