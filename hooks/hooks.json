{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "${PLUGIN_DIR}/bin/check-read-target"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${PLUGIN_DIR}/bin/rewrite-bash"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${PLUGIN_DIR}/bin/scan-edit"
          }
        ]
      }
    ]
  }
}
